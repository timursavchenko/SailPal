{

	// Qt settings
	"qt-core.additionalQtPaths": [
		{
			"name": "CDK Qt 6.9.2",
			"path": "/Users/zen/Projects/CDK/targets/macOS/x86_64/usr/bin/qtpaths"
		}
	],
	"qt-qml.qmlls.additionalImportPaths": [
		"/Users/zen/Projects/CDK/targets/macOS/x86_64/usr/qml"
	],
	"qt-qml.qmlls.useQmlImportPathEnvVar": true,
	"qt-qml.qmlls.useNoCMakeCalls": true,
	"qt-qml.qmlls.verboseOutput": true,
	"qt-qml.qmlls.enabled": true,

	// CMake settings
	"cmake.buildBeforeRun": false,
	"cmake.configureOnEdit": false,
	"cmake.configureOnOpen": false,

	// CodeLLDB: bypass xcrun-based debugserver discovery.
	"lldb.server": "/Applications/Xcode.app/Contents/SharedFrameworks/LLDB.framework/Versions/A/Resources/debugserver",

	// Показывать пробелы/табы/переносы
	"editor.renderWhitespace": "all",

	// Show control characters (e.g., \u200B, BOM)
	"editor.renderControlCharacters": true,
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	"editor.tabSize": 4,
	"editor.formatOnSave": false,

	// Hide some files/folders
	"files.exclude": {
		"**/_build": true,
		"**/.DS_Store": true,
		"**/.gitignore": true,
		"**/.gitmodules": true
	},

	// Ignore some files for spell checking
	"cSpell.ignorePaths": [
		"package-lock.json",
		"node_modules",
		"vscode-extension",
		".git/{info,lfs,logs,refs,objects}/**",
		".git/{index,*refs,*HEAD}",
		".vscode",
		".vscode-insiders",
		"*/translations.xml"
	],

